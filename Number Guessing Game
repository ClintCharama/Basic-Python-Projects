 #game
from random import *
def game():

  number = randrange(0, 100)
  attempts = 0
  correct = False

  print('Guess the number between 0 and 100')
  while attempts < 5 and not correct:

    try:
      guess = int(input())
    except Exception as ex:
      print('Please enter a valid number\n')
      continue
    else:
      if guess == number:
        correct = True
        print('You have guessed the correct number')
      else:
        attempts += 1
        if guess > number:
          print('Too high')
        elif guess < number:
          print('Too low')
        print(f'You have {5 - attempts} guesses left')
        print()
  if correct is False: print(f'You lost. The correct number was {number}')
  print('\n\n\n')
  

